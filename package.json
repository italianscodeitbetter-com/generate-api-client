{
  "name": "@icib.dev/api-client",
  "version": "1.0.0",
  "description": "Strictly-typed TypeScript API client for ICIB/GSS API",
  "type": "module",
  "main": "./dist/api/index.js",
  "types": "./dist/api/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js",
      "default": "./dist/api/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run generate && npm run build"
  },
  "dependencies": {
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^10.0.3",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "api-client",
    "icib",
    "typescript",
    "axios",
    "openapi"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/italianscodeitbetter-com/generate-api-client"
  },
  "license": "MIT"
}